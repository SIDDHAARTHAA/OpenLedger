generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum AuthProvider {
  GOOGLE
  EMAIL
}

enum UserRole {
  VIEWER
  ANALYST
  ADMIN
}

enum UserStatus {
  ACTIVE
  INACTIVE
}

enum TransactionType {
  DEPOSIT
  WITHDRAW
  TRANSFER_IN
  TRANSFER_OUT
}

enum TransactionStatus {
  PENDING
  SUCCESS
  FAILED
}

enum FinancialRecordType {
  INCOME
  EXPENSE
}

model User {
  id     String     @id @default(cuid())
  email  String?    @unique
  role   UserRole   @default(VIEWER)
  status UserStatus @default(ACTIVE)

  name  String?
  image String?

  authAccounts AuthAccount[]
  sessions     Session[]
  account      Account?
  assetPurchases AssetPurchase[]
  createdFinancialRecords FinancialRecord[] @relation("CreatedFinancialRecords")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AuthAccount {
  id                String       @id @default(cuid())
  userId            String
  provider          AuthProvider
  providerAccountId String

  passwordHash String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([provider, providerAccountId])
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  expiresAt DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([userId])
}

model Account {
  id      String @id @default(cuid())
  userId  String @unique
  balance BigInt @default(0)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  transactions Transaction[]

  createdAt DateTime @default(now())
}

model Transaction {
  id        String            @id @default(cuid())
  accountId String
  amount    BigInt
  type      TransactionType
  status    TransactionStatus
  reference String?           @unique

  account Account @relation(fields: [accountId], references: [id])
  processing Processing?
  assetPurchase AssetPurchase?

  createdAt DateTime @default(now())
}

model Processing {
  id            String   @id @default(cuid())
  bankToken     String   @unique
  transactionId String   @unique
  settledAt     DateTime?

  transaction Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AssetPurchase {
  id            String @id @default(cuid())
  userId        String
  transactionId String @unique

  assetId   String
  assetName String
  price     BigInt

  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  transaction Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([userId, assetId])
  @@index([userId, createdAt])
}

model FinancialRecord {
  id          String              @id @default(cuid())
  createdById String
  amount      BigInt
  type        FinancialRecordType
  category    String
  entryDate   DateTime
  notes       String?

  createdBy User @relation("CreatedFinancialRecords", fields: [createdById], references: [id], onDelete: Restrict)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([createdById, createdAt])
  @@index([type, entryDate])
  @@index([category, entryDate])
}
