generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum AuthProvider {
  GOOGLE
  EMAIL
}

enum UserRole {
  VIEWER
  ANALYST
  ADMIN
}

enum UserStatus {
  ACTIVE
  INACTIVE
}

enum FinancialRecordType {
  INCOME
  EXPENSE
}

model User {
  id     String     @id @default(cuid())
  email  String?    @unique
  role   UserRole   @default(VIEWER)
  status UserStatus @default(ACTIVE)

  name  String?
  image String?

  authAccounts AuthAccount[]
  sessions     Session[]
  createdFinancialRecords FinancialRecord[] @relation("CreatedFinancialRecords")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AuthAccount {
  id                String       @id @default(cuid())
  userId            String
  provider          AuthProvider
  providerAccountId String

  passwordHash String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([provider, providerAccountId])
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  expiresAt DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([userId])
}

model FinancialRecord {
  id          String              @id @default(cuid())
  createdById String
  amount      BigInt
  type        FinancialRecordType
  category    String
  entryDate   DateTime
  notes       String?

  createdBy User @relation("CreatedFinancialRecords", fields: [createdById], references: [id], onDelete: Restrict)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([createdById, createdAt])
  @@index([type, entryDate])
  @@index([category, entryDate])
}
